{
  "functions": [
    {
      "source": "functions",
      "codebase": "legacy",
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" install",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug..log",
        ".local"
      ]
    },
    {
      "source": "functions-stripe",
      "codebase": "stripe",
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" install",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug..log",
        ".local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "site": "meumei-d88be",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/createCheckoutSessionV2",
          "function": {
            "functionId": "createCheckoutSessionV2",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/grantEntitlementV2",
          "function": {
            "functionId": "grantEntitlementV2",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/askMeumeiHelper",
          "function": {
            "functionId": "askMeumeiHelper",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/sendPushNotification",
          "function": {
            "functionId": "sendPushNotification",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/createBetaKey",
          "function": {
            "functionId": "createBetaKey",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/listBetaKeys",
          "function": {
            "functionId": "listBetaKeys",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/revokeBetaKey",
          "function": {
            "functionId": "revokeBetaKey",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/deleteBetaKey",
          "function": {
            "functionId": "deleteBetaKey",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/grantLifetimeAccess",
          "function": {
            "functionId": "grantLifetimeAccess",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/redeemBetaKey",
          "function": {
            "functionId": "redeemBetaKey",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/requestTrialKey",
          "function": {
            "functionId": "requestTrialKey",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/masterMetrics",
          "function": {
            "functionId": "masterMetrics",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
